struct Foo {
    a: i32,
    b: f64,

    fn simple(x: i32) -> i32 {
        return x;
    }
}

fn two() -> i8 {
    return 2;
}

fn foo(x: u8) -> bool {
    let f = Foo{0, 4.0};
    let m = 1 * 2 - (3 + -two()) + (f.simple(f.a as i32) as u8) / 10;
    if x > 4 {
        x = 4;
    } else if x > 2 {
        x = 2;
    } else {
        return false;
    }

    while x >= 100 {
        x += 1;
    }

    let j = 4..10;

    for i in j {
        x += i;
    }

    return (x > 1);
}

fn main(argv: u32) -> () {
    let mut x = Foo{0, 10.0};
    x.a = 0;
    x.b = 4.0;

    std::println("Hello, world!");
    std::println("x = {}", x);
}
